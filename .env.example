# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://teriyakiturf.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_key_here

# Kit (ConvertKit) — email capture
KIT_API_KEY=
KIT_FORM_ID=
# Optional: numeric Kit tag id for the fertilizer waitlist. If unset, the tag
# is resolved by name ("fertilizer-waitlist") via the Kit tags API.
KIT_FERTILIZER_TAG_ID=

# Stripe — $67 one-time (lifetime lawn plan). Use sk_live_ / whsec_ (live) in production.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Database (Supabase)
DATABASE_URL=
DIRECT_URL=

# OpenWeatherMap (optional — for live soil temp)
OWM_API_KEY=
